########################
# 1. IDE / 编辑器配置
########################

# VSCode 配置（launch.json, settings.json 等）
.vscode/

# JetBrains / CLion / IDEA 等
.idea/

# crossnote 配置
.crossnote/


########################
# 2. CPH 插件生成的目录
########################

# 所有名字叫 .cph 的目录（任意层级）
.cph/

########################
# 3. 编译产物 / 临时文件（C / C++ 等）
########################

# Windows 可执行文件
*.exe
*.exe.stackdump

# 常见目标文件
*.o
*.obj
*.a
*.lib

# 编译产生的日志
*.log
*.err

# Visual Studio 相关
*.pdb
*.ilk

# stress 对拍器
*.stress/


########################
# 4. LaTeX 中间文件
########################

# 常见中间文件
*.aux
*.auxlock
*.log
*.out
*.toc
*.lof
*.lot
*.lol
*.loa
*.lof
*.lot
*.bbl
*.blg
*.brf
*.idx
*.ilg
*.ind
*.ist
*.glo
*.glg
*.gls
*.fls
*.fdb_latexmk
*.synctex
*.synctex.gz
*.synctex(busy)

# beamer / slides 相关
*.nav
*.snm
*.vrb

# minted 使用 externalize 时的高亮缓存
_minted*/

# 其他常见辅助文件
*.run.xml
*.toclock

# 如果你不想同步编译出的 dvi/ps，也可以顺手忽略
*.dvi
*.ps

# 注意：不要在这里忽略 .tex / .sty / .cls / .bib / .pdf
# 这些通常是你想在两台机器上共享的

########################
# 5. 其他常见杂项
########################

# macOS
.DS_Store

# 通用备份文件
*~
*.swp
*.swo
